{
  "name": "check-the-lease",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./frontend/dist/public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "LLM_PROVIDER": "groq"
  },
  "d1_databases": [
    { "binding": "DB", "database_name": "check-the-lease-db", "database_id": "1768499d-8067-402f-9b57-a669776d793c" }
  ],
  "observability": {
    "enabled": true
  }
}
